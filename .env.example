# Copy this file to .env and fill only the services you decide to use.
# Never commit .env.

FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
# Primary live source. Valid values are football_data and api_football.
WORLD_CUP_PROVIDER=football_data
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION_CODE=WC
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
WORLD_CUP_HTTP_TIMEOUT_SECONDS=15
WORLD_CUP_HTTP_RETRIES=2
WORLD_CUP_RATE_LIMIT_SECONDS=1
WORLD_CUP_CACHE_TTL_SECONDS=300
OPEN_METEO_BASE_URL=https://api.open-meteo.com
